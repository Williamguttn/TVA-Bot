{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.ts",
    "api/**/*.ts",
    "commands/**/*.ts",
    "database/**/*.ts",
    "misc/**/*.ts",
    "types.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}